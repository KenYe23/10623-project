# Bedrock credentials
AWS_BEARER_TOKEN_BEDROCK=YOUR_BEDROCK_BEARER_TOKEN
AWS_BEDROCK_REGION=us-east-1

# Local FLUX.2 server endpoint used by VisualizerAgent
FLUX2_SERVER_URL=http://localhost:30000

# Optional explicit local model paths (if not set, Flux2 code may download from HF cache)
FLUX2_MODEL_PATH=/path/to/flux2-dev.safetensors
AE_MODEL_PATH=/path/to/ae.safetensors
